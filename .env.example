# ============================================================
# GymCoach - Environment variables
# ============================================================
# Copy this file to .env and fill in the values.
# .env is ignored by git (see .gitignore).

# --- Database ---
# Local dev: "db" is the docker-compose service name. If you run Postgres via
# docker compose but Next.js locally, use "localhost" instead of "db".
DATABASE_URL=postgresql://gymcoach:gymcoach_dev_pwd@localhost:5433/gymcoach

# Variables used by the docker-compose "db" service:
POSTGRES_USER=gymcoach
POSTGRES_PASSWORD=gymcoach_dev_pwd
POSTGRES_DB=gymcoach

# --- Authentication ---
# Generate 64 random chars: openssl rand -base64 48
JWT_SECRET=replace-me-with-openssl-rand-base64-48

# Demo account created by the seed (password is hashed at seed time)
USER_EMAIL=you@example.com
USER_PASSWORD=change-me-immediately

# --- AI coach ---
# Choose the LLM provider: "anthropic" (default), "openrouter", or "demo".
# "demo" returns canned responses with no API key, handy to try the AI screens.
LLM_PROVIDER=anthropic

# Option A: Anthropic API (used when LLM_PROVIDER=anthropic)
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Defaults to claude-opus-4-7. Use claude-sonnet-4-6 or claude-haiku-4-5 to
# trade some quality for lower cost.
ANTHROPIC_MODEL=claude-opus-4-7

# Option B: OpenRouter (used when LLM_PROVIDER=openrouter)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Exact model id on OpenRouter (see https://openrouter.ai/models).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional: title/URL sent in the OpenRouter headers for attribution.
OPENROUTER_APP_NAME=GymCoach
OPENROUTER_APP_URL=http://localhost:3030

# --- App ---
NEXTAUTH_URL=http://localhost:3030
NODE_ENV=development
