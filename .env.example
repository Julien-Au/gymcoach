# ============================================================
# GymCoach - Variables d'environnement
# ============================================================
# Copier ce fichier en .env et remplir les valeurs.
# .env est ignoré par git (cf. .gitignore).

# --- Base de données ---
# En dev local : "db" est le nom du service docker-compose.
# Si tu lances Postgres via docker compose mais Next.js en local,
# utiliser "localhost" au lieu de "db".
DATABASE_URL=postgresql://gymcoach:gymcoach_dev_pwd@localhost:5433/gymcoach

# Variables utilisées par le service "db" du docker-compose :
POSTGRES_USER=gymcoach
POSTGRES_PASSWORD=gymcoach_dev_pwd
POSTGRES_DB=gymcoach

# --- Authentification ---
# Générer 64 chars random : openssl rand -base64 48
JWT_SECRET=replace-me-with-openssl-rand-base64-48

# Identifiants du compte de démo créé par le seed (hashé au seed)
USER_EMAIL=you@example.com
USER_PASSWORD=change-me-immediately

# --- Coach IA (LOT 9) - via OpenRouter ---
# Récupérer une clé sur https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Identifiant exact du modèle sur OpenRouter (cf. https://openrouter.ai/models).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optionnel : titre/URL envoyés dans les headers OpenRouter pour l'attribution.
OPENROUTER_APP_NAME=GymCoach
OPENROUTER_APP_URL=http://localhost:3030

# --- App ---
NEXTAUTH_URL=http://localhost:3030
NODE_ENV=development
